# Copy this file to .env and fill in your key.

# Required: OpenAI API key from a funded account.
OPENAI_API_KEY=

# Optional: logging verbosity (DEBUG, INFO, WARNING, ERROR). Default: INFO.
# LOG_LEVEL=INFO

# Optional: document indexed by index_pipeline.py.
# SOURCE_URL=https://lilianweng.github.io/posts/2023-06-23-agent/

# Optional: question asked by rag_pipeline.py and eval_pipeline.py.
# QUERY=What are the approaches to Task Decomposition?

# Optional: set to any value to skip the interactive human-grade step in eval_pipeline.py.
# SKIP_HUMAN_EVAL=1
